{
  "name": "v.logue.dev",
  "description": "A personal portfolio site about programming, technology, and software development.",
  "author": {
    "name": "Logue",
    "email": "logue@hotmail.co.jp",
    "url": "https://logue.dev"
  },
  "homepage": "https://v.logue.dev",
  "repository": {
    "type": "git",
    "url": "https://github.com/logue/v.logue.dev.git"
  },
  "license": "MIT",
  "private": true,
  "type": "module",
  "version": "2.1.4",
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "dev": "vite",
    "dev:wrangler": "wrangler pages dev",
    "types": "wrangler types",
    "lint": "run-s lint:*",
    "lint:oxlint": "oxlint . --fix",
    "lint:eslint": "eslint . --fix --cache --cache-location ./node_modules/.vite/eslint-cache",
    "lint:prettier": "prettier \"./**/*.{js,ts,json,css,sass,scss,htm,html,vue,md}\" -w -u",
    "lint:style": "stylelint \"./**/*.{css,sass,scss,htm,html,vue}\" --fix --cache-location ./node_modules/.vite/stylelint-cache && prettier \"./**/*.{css,sass,scss,htm,html,vue}\" -w -u",
    "build": "vue-tsc -b && vite build",
    "preview": "vite preview",
    "type-check": "vue-tsc --build"
  },
  "dependencies": {
    "@pixiv/three-vrm": "^3.5.1",
    "@pixiv/three-vrm-animation": "^3.5.1",
    "@popperjs/core": "^2.11.8",
    "bootstrap": "^5.3.8",
    "fflate": "^0.8.2",
    "pinia": "^3.0.4",
    "three": "^0.183.2",
    "vue": "^3.5.32",
    "vue-router": "^5.0.4"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.31.2",
    "@cloudflare/workers-types": "^4.20260410.1",
    "@iconify-json/bi": "^1.2.7",
    "@iconify-json/simple-icons": "^1.2.77",
    "@iconify/vue": "^5.0.0",
    "@tsconfig/node-lts": "^24.0.0",
    "@types/bootstrap": "^5.2.10",
    "@types/node": "^25.6.0",
    "@types/three": "^0.183.1",
    "@vitejs/plugin-vue": "^6.0.5",
    "@vue/eslint-config-prettier": "^10.2.0",
    "@vue/eslint-config-typescript": "^14.7.0",
    "@vue/tsconfig": "^0.9.1",
    "eslint": "^10.2.0",
    "eslint-import-resolver-custom-alias": "^1.3.2",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import-x": "^4.16.2",
    "eslint-plugin-oxlint": "^1.59.0",
    "eslint-plugin-security": "^4.0.0",
    "eslint-plugin-vue": "^10.8.0",
    "eslint-plugin-vuejs-accessibility": "^2.5.0",
    "jiti": "^2.6.1",
    "lint-staged": "^16.4.0",
    "npm-run-all2": "^8.0.4",
    "oxlint": "^1.59.0",
    "prettier": "^3.8.2",
    "rimraf": "^6.1.3",
    "sass-embedded": "^1.99.0",
    "stylelint": "^17.6.0",
    "stylelint-config-html": "^1.1.0",
    "stylelint-config-recommended-scss": "^17.0.1",
    "stylelint-config-recommended-vue": "^1.6.1",
    "stylelint-order": "^8.1.1",
    "stylelint-scss": "^7.0.0",
    "typescript": "^6.0.2",
    "vite": "^8.0.8",
    "vite-plugin-checker": "^0.12.0",
    "vite-plugin-glsl": "^1.6.0",
    "vite-plugin-javascript-obfuscator": "^3.1.0",
    "vite-plugin-vue-devtools": "^8.1.1",
    "vue-tsc": "^3.2.6",
    "wrangler": "^4.81.1"
  },
  "husky": {
    "hooks": {
      "pre-commit": "lint-staged"
    }
  },
  "lint-staged": {
    "*": "run-s lint:*"
  },
  "resolutions": {
    "js-yaml": ">=4.1.1",
    "picomatch": ">=2.3.2"
  }
}
